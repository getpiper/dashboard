# Copy to .env for local development (bun loads it automatically).

# Base URL of the relay control API — the same URL `piper login --relay` takes.
# Required; the server throws on startup requests if unset. Server-only, never
# exposed to the client bundle.
# For local development against a stub relay, point it at your stub's port.
PIPER_RELAY_URL=https://relay.example.com

# Port the production server listens on. The Dockerfile sets 8080 (piper's
# app-container default); `bun run dev` ignores this and serves on 3000.
# PORT=8080
